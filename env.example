# Токен Telegram бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API ключ для прокси OpenRouter (api.proxyapi.ru)
# Используется для моделей: openrouter (DeepSeek Chat) и reasoning (DeepSeek R1)
PROXY_API_KEY=your_proxy_api_key_here

# Ключ авторизации GigaChat (для получения токена через get_token_gch.py)
# Формат: client_id:client_secret (например: d59e9212-fa77-4cb3-9fc6-731ca55ff49d:39b27875-9da7-41f1-bb28-9cbfda53e3b7)
# Или base64 строка без префикса "Basic " (например: ZDU5ZTkyMTItZmE3Ny00Y2IzLTlmYzYtNzMxY2E1NWZmNDlkOjM5YjI3ODc1LTlkYTctNDFmMS1iYjI4LTljYmZkYTUzZTNiNw==)
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here

# Проверка SSL сертификата для GigaChat (true/false). 
# По умолчанию false из-за проблем с самоподписанными сертификатами Sberbank
GIGACHAT_VERIFY_SSL=false

# API ключ Yandex Cloud для работы с Yandex GPT
YANDEX_API_KEY=your_yandex_api_key_here

# ID каталога Yandex Cloud (Folder ID)
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# Модель Yandex GPT (yandexgpt, yandexgpt-lite, yandexgpt-pro). По умолчанию: yandexgpt
YANDEX_MODEL=yandexgpt

# Ollama (локальная модель)
# Обычно Ollama слушает локально: http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Рекомендуемые модели (алгоритм выбора под слабый CPU):
# - Быстро и стабильно (рекомендуем для сервера): Gemma-2-2B (Q4_K_M)
#   ollama pull gemma2:2b-instruct-q4_K_M
# - Если хочется чуть лучше качество и терпима скорость: Qwen2.5-3B-Instruct (Q4_K_M)
#   ollama pull qwen2.5:3b-instruct-q4_K_M
# - Если всё ещё медленно: Qwen2.5-1.5B (Q4_K_M)
#   ollama pull qwen2.5:1.5b-instruct-q4_K_M
OLLAMA_MODEL=gemma2:2b-instruct-q4_K_M

# Таймаут запроса к Ollama (сек). На слабом CPU лучше ставить выше.
OLLAMA_TIMEOUT=180

# Ограничение длины ответа (токены). Это критично для стабильной работы "балабола" на CPU.
OLLAMA_NUM_PREDICT=256

# Better Stack Logs (Logtail)
# Не коммить свои реальные токены/хосты в репозиторий.
# Source Token (Logs -> Source -> Source token)
BETTERSTACK_SOURCE_TOKEN=your_betterstack_source_token_here
# Ingesting Host вида: sXXXX.region.betterstackdata.com (без https://)
BETTERSTACK_INGEST_HOST=your_betterstack_ingest_host_here

# (опционально) соль для хеширования Telegram user_id в логах (для приватности)
TELEMETRY_USER_HASH_SALT=change_me

# (опционально) уровень логирования: DEBUG/INFO/WARNING/ERROR
TELEMETRY_LEVEL=INFO

# Озвучка ответов (TTS) — Yandex SpeechKit
# Используются YANDEX_API_KEY и YANDEX_FOLDER_ID (те же, что для Yandex GPT).
# У сервисного аккаунта должна быть роль speechkit.speaker.
# Максимальная длина текста для озвучки (символов). По умолчанию: 5000
TTS_MAX_CHARS=5000
